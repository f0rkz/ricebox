  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#5F6F5A", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A3D977" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#6DB8A0" } },
    { "scope": "constant.language", "settings": { "foreground": "#6DB8A0" } },
    { "scope": "constant.character", "settings": { "foreground": "#6DB8A0" } },
    { "scope": "variable", "settings": { "foreground": "#D3E7C5" } },
    { "scope": "variable.language", "settings": { "foreground": "#E16D6D" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#D3E7C5", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#C48FBF" } },
    { "scope": "keyword.control", "settings": { "foreground": "#C48FBF" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#8FA882" } },
    { "scope": "storage", "settings": { "foreground": "#C48FBF" } },
    { "scope": "storage.type", "settings": { "foreground": "#D4C96E" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#7BC4B2" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#D4C96E" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#D4C96E" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#A3D977" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#7BC4B2" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#7BC4B2" } },
    { "scope": "support.function", "settings": { "foreground": "#7BC4B2" } },
    { "scope": "support.type", "settings": { "foreground": "#D4C96E" } },
    { "scope": "support.class", "settings": { "foreground": "#D4C96E" } },
    { "scope": "support.constant", "settings": { "foreground": "#6DB8A0" } },
    { "scope": "punctuation", "settings": { "foreground": "#8FA882" } },
    { "scope": "meta.tag", "settings": { "foreground": "#D3E7C5" } },
    { "scope": "meta.brace", "settings": { "foreground": "#8FA882" } },
    { "scope": "markup.heading", "settings": { "foreground": "#A3D977", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#A3D977" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#E16D6D" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#A3D977" } },
    { "scope": "markup.changed", "settings": { "foreground": "#D4C96E" } },
    { "scope": "markup.list", "settings": { "foreground": "#D3E7C5" } },
    { "scope": "markup.quote", "settings": { "foreground": "#7BC4B2", "fontStyle": "italic" } }
  ]
}
