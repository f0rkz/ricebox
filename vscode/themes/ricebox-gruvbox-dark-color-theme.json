  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#665C54", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#98971A" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#689D6A" } },
    { "scope": "constant.language", "settings": { "foreground": "#689D6A" } },
    { "scope": "constant.character", "settings": { "foreground": "#689D6A" } },
    { "scope": "variable", "settings": { "foreground": "#EBDBB2" } },
    { "scope": "variable.language", "settings": { "foreground": "#CC241D" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#EBDBB2", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#B16286" } },
    { "scope": "keyword.control", "settings": { "foreground": "#B16286" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#928374" } },
    { "scope": "storage", "settings": { "foreground": "#B16286" } },
    { "scope": "storage.type", "settings": { "foreground": "#D79921" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#458588" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#D79921" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#D79921" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#B8BB26" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#458588" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#83A598" } },
    { "scope": "support.function", "settings": { "foreground": "#458588" } },
    { "scope": "support.type", "settings": { "foreground": "#D79921" } },
    { "scope": "support.class", "settings": { "foreground": "#D79921" } },
    { "scope": "support.constant", "settings": { "foreground": "#689D6A" } },
    { "scope": "punctuation", "settings": { "foreground": "#928374" } },
    { "scope": "meta.tag", "settings": { "foreground": "#EBDBB2" } },
    { "scope": "meta.brace", "settings": { "foreground": "#928374" } },
    { "scope": "markup.heading", "settings": { "foreground": "#B8BB26", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#98971A" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#CC241D" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#98971A" } },
    { "scope": "markup.changed", "settings": { "foreground": "#D79921" } },
    { "scope": "markup.list", "settings": { "foreground": "#EBDBB2" } },
    { "scope": "markup.quote", "settings": { "foreground": "#83A598", "fontStyle": "italic" } }
  ]
}
