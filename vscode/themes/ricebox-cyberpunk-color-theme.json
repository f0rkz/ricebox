  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#4A3A6A", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#00FF9F" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#00FFFF" } },
    { "scope": "constant.language", "settings": { "foreground": "#00FFFF" } },
    { "scope": "constant.character", "settings": { "foreground": "#00FFFF" } },
    { "scope": "variable", "settings": { "foreground": "#E0D0FF" } },
    { "scope": "variable.language", "settings": { "foreground": "#FF2079" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#E0D0FF", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#FF00FF" } },
    { "scope": "keyword.control", "settings": { "foreground": "#FF00FF" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#7B6B99" } },
    { "scope": "storage", "settings": { "foreground": "#FF00FF" } },
    { "scope": "storage.type", "settings": { "foreground": "#FFD700" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#00BFFF" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#FFD700" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#FFD700" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#FF00FF" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#00BFFF" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#00FFFF" } },
    { "scope": "support.function", "settings": { "foreground": "#00BFFF" } },
    { "scope": "support.type", "settings": { "foreground": "#FFD700" } },
    { "scope": "support.class", "settings": { "foreground": "#FFD700" } },
    { "scope": "support.constant", "settings": { "foreground": "#00FFFF" } },
    { "scope": "punctuation", "settings": { "foreground": "#7B6B99" } },
    { "scope": "meta.tag", "settings": { "foreground": "#E0D0FF" } },
    { "scope": "meta.brace", "settings": { "foreground": "#7B6B99" } },
    { "scope": "markup.heading", "settings": { "foreground": "#FF00FF", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#00FF9F" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#FF2079" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#00FF9F" } },
    { "scope": "markup.changed", "settings": { "foreground": "#FFD700" } },
    { "scope": "markup.list", "settings": { "foreground": "#E0D0FF" } },
    { "scope": "markup.quote", "settings": { "foreground": "#00FFFF", "fontStyle": "italic" } }
  ]
}
