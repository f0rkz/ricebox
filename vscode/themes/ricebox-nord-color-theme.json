  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#4C566A", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A3BE8C" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#88C0D0" } },
    { "scope": "constant.language", "settings": { "foreground": "#88C0D0" } },
    { "scope": "constant.character", "settings": { "foreground": "#88C0D0" } },
    { "scope": "variable", "settings": { "foreground": "#ECEFF4" } },
    { "scope": "variable.language", "settings": { "foreground": "#BF616A" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#ECEFF4", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#B48EAD" } },
    { "scope": "keyword.control", "settings": { "foreground": "#B48EAD" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#7B88A1" } },
    { "scope": "storage", "settings": { "foreground": "#B48EAD" } },
    { "scope": "storage.type", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#81A1C1" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#88C0D0" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#81A1C1" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#A3BE8C" } },
    { "scope": "support.function", "settings": { "foreground": "#81A1C1" } },
    { "scope": "support.type", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "support.class", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "support.constant", "settings": { "foreground": "#88C0D0" } },
    { "scope": "punctuation", "settings": { "foreground": "#7B88A1" } },
    { "scope": "meta.tag", "settings": { "foreground": "#ECEFF4" } },
    { "scope": "meta.brace", "settings": { "foreground": "#7B88A1" } },
    { "scope": "markup.heading", "settings": { "foreground": "#88C0D0", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#A3BE8C" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#BF616A" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#A3BE8C" } },
    { "scope": "markup.changed", "settings": { "foreground": "#EBCB8B" } },
    { "scope": "markup.list", "settings": { "foreground": "#ECEFF4" } },
    { "scope": "markup.quote", "settings": { "foreground": "#A3BE8C", "fontStyle": "italic" } }
  ]
}
