  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#586E75", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#859900" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#2AA198" } },
    { "scope": "constant.language", "settings": { "foreground": "#2AA198" } },
    { "scope": "constant.character", "settings": { "foreground": "#2AA198" } },
    { "scope": "variable", "settings": { "foreground": "#839496" } },
    { "scope": "variable.language", "settings": { "foreground": "#DC322F" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#839496", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#D33682" } },
    { "scope": "keyword.control", "settings": { "foreground": "#D33682" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#586E75" } },
    { "scope": "storage", "settings": { "foreground": "#D33682" } },
    { "scope": "storage.type", "settings": { "foreground": "#B58900" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#268BD2" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#B58900" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#B58900" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#268BD2" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#268BD2" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#2AA198" } },
    { "scope": "support.function", "settings": { "foreground": "#268BD2" } },
    { "scope": "support.type", "settings": { "foreground": "#B58900" } },
    { "scope": "support.class", "settings": { "foreground": "#B58900" } },
    { "scope": "support.constant", "settings": { "foreground": "#2AA198" } },
    { "scope": "punctuation", "settings": { "foreground": "#586E75" } },
    { "scope": "meta.tag", "settings": { "foreground": "#839496" } },
    { "scope": "meta.brace", "settings": { "foreground": "#586E75" } },
    { "scope": "markup.heading", "settings": { "foreground": "#268BD2", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#859900" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#DC322F" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#859900" } },
    { "scope": "markup.changed", "settings": { "foreground": "#B58900" } },
    { "scope": "markup.list", "settings": { "foreground": "#839496" } },
    { "scope": "markup.quote", "settings": { "foreground": "#2AA198", "fontStyle": "italic" } }
  ]
}
