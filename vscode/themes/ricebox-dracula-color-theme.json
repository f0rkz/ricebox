  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#6272A4", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#50FA7B" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#8BE9FD" } },
    { "scope": "constant.language", "settings": { "foreground": "#8BE9FD" } },
    { "scope": "constant.character", "settings": { "foreground": "#8BE9FD" } },
    { "scope": "variable", "settings": { "foreground": "#F8F8F2" } },
    { "scope": "variable.language", "settings": { "foreground": "#FF5555" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#F8F8F2", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#FF79C6" } },
    { "scope": "keyword.control", "settings": { "foreground": "#FF79C6" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#6272A4" } },
    { "scope": "storage", "settings": { "foreground": "#FF79C6" } },
    { "scope": "storage.type", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#BD93F9" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#BD93F9" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#BD93F9" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#8BE9FD" } },
    { "scope": "support.function", "settings": { "foreground": "#BD93F9" } },
    { "scope": "support.type", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "support.class", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "support.constant", "settings": { "foreground": "#8BE9FD" } },
    { "scope": "punctuation", "settings": { "foreground": "#6272A4" } },
    { "scope": "meta.tag", "settings": { "foreground": "#F8F8F2" } },
    { "scope": "meta.brace", "settings": { "foreground": "#6272A4" } },
    { "scope": "markup.heading", "settings": { "foreground": "#BD93F9", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#50FA7B" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#FF5555" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#50FA7B" } },
    { "scope": "markup.changed", "settings": { "foreground": "#F1FA8C" } },
    { "scope": "markup.list", "settings": { "foreground": "#F8F8F2" } },
    { "scope": "markup.quote", "settings": { "foreground": "#8BE9FD", "fontStyle": "italic" } }
  ]
}
