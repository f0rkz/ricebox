  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#54546D", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#76946A" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#6A9589" } },
    { "scope": "constant.language", "settings": { "foreground": "#6A9589" } },
    { "scope": "constant.character", "settings": { "foreground": "#6A9589" } },
    { "scope": "variable", "settings": { "foreground": "#DCD7BA" } },
    { "scope": "variable.language", "settings": { "foreground": "#C34043" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#DCD7BA", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#957FB8" } },
    { "scope": "keyword.control", "settings": { "foreground": "#957FB8" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#727169" } },
    { "scope": "storage", "settings": { "foreground": "#957FB8" } },
    { "scope": "storage.type", "settings": { "foreground": "#C0A36E" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#7E9CD8" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#C0A36E" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#C0A36E" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#7E9CD8" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#7E9CD8" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#6A9589" } },
    { "scope": "support.function", "settings": { "foreground": "#7E9CD8" } },
    { "scope": "support.type", "settings": { "foreground": "#C0A36E" } },
    { "scope": "support.class", "settings": { "foreground": "#C0A36E" } },
    { "scope": "support.constant", "settings": { "foreground": "#6A9589" } },
    { "scope": "punctuation", "settings": { "foreground": "#727169" } },
    { "scope": "meta.tag", "settings": { "foreground": "#DCD7BA" } },
    { "scope": "meta.brace", "settings": { "foreground": "#727169" } },
    { "scope": "markup.heading", "settings": { "foreground": "#7E9CD8", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#76946A" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#C34043" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#76946A" } },
    { "scope": "markup.changed", "settings": { "foreground": "#C0A36E" } },
    { "scope": "markup.list", "settings": { "foreground": "#DCD7BA" } },
    { "scope": "markup.quote", "settings": { "foreground": "#6A9589", "fontStyle": "italic" } }
  ]
}
