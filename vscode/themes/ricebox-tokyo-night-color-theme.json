  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#444B6A", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#9ECE6A" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#7DCFFF" } },
    { "scope": "constant.language", "settings": { "foreground": "#7DCFFF" } },
    { "scope": "constant.character", "settings": { "foreground": "#7DCFFF" } },
    { "scope": "variable", "settings": { "foreground": "#C0CAF5" } },
    { "scope": "variable.language", "settings": { "foreground": "#F7768E" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#C0CAF5", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#BB9AF7" } },
    { "scope": "keyword.control", "settings": { "foreground": "#BB9AF7" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#565F89" } },
    { "scope": "storage", "settings": { "foreground": "#BB9AF7" } },
    { "scope": "storage.type", "settings": { "foreground": "#E0AF68" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#7AA2F7" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#E0AF68" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#E0AF68" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#7AA2F7" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#7AA2F7" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#9ECE6A" } },
    { "scope": "support.function", "settings": { "foreground": "#7AA2F7" } },
    { "scope": "support.type", "settings": { "foreground": "#E0AF68" } },
    { "scope": "support.class", "settings": { "foreground": "#E0AF68" } },
    { "scope": "support.constant", "settings": { "foreground": "#7DCFFF" } },
    { "scope": "punctuation", "settings": { "foreground": "#565F89" } },
    { "scope": "meta.tag", "settings": { "foreground": "#C0CAF5" } },
    { "scope": "meta.brace", "settings": { "foreground": "#565F89" } },
    { "scope": "markup.heading", "settings": { "foreground": "#7AA2F7", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#9ECE6A" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#F7768E" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#9ECE6A" } },
    { "scope": "markup.changed", "settings": { "foreground": "#E0AF68" } },
    { "scope": "markup.list", "settings": { "foreground": "#C0CAF5" } },
    { "scope": "markup.quote", "settings": { "foreground": "#9ECE6A", "fontStyle": "italic" } }
  ]
}
