    { "scope": "markup.changed", "settings": { "foreground": "#F6C177" } },
    { "scope": "markup.list", "settings": { "foreground": "#E0DEF4" } },
    { "scope": "markup.quote", "settings": { "foreground": "#9CCFD8", "fontStyle": "italic" } }
