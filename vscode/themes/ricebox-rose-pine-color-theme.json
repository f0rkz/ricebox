  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#524F67", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#31748F" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#9CCFD8" } },
    { "scope": "constant.language", "settings": { "foreground": "#9CCFD8" } },
    { "scope": "constant.character", "settings": { "foreground": "#9CCFD8" } },
    { "scope": "variable", "settings": { "foreground": "#E0DEF4" } },
    { "scope": "variable.language", "settings": { "foreground": "#EB6F92" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#E0DEF4", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#EA9A97" } },
    { "scope": "keyword.control", "settings": { "foreground": "#EA9A97" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#6E6A86" } },
    { "scope": "storage", "settings": { "foreground": "#EA9A97" } },
    { "scope": "storage.type", "settings": { "foreground": "#F6C177" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#C4A7E7" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#F6C177" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#F6C177" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#C4A7E7" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#C4A7E7" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#9CCFD8" } },
    { "scope": "support.function", "settings": { "foreground": "#C4A7E7" } },
    { "scope": "support.type", "settings": { "foreground": "#F6C177" } },
    { "scope": "support.class", "settings": { "foreground": "#F6C177" } },
    { "scope": "support.constant", "settings": { "foreground": "#9CCFD8" } },
    { "scope": "punctuation", "settings": { "foreground": "#6E6A86" } },
    { "scope": "meta.tag", "settings": { "foreground": "#E0DEF4" } },
    { "scope": "meta.brace", "settings": { "foreground": "#6E6A86" } },
