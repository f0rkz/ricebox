  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#585B70", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A6E3A1" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#94E2D5" } },
    { "scope": "constant.language", "settings": { "foreground": "#94E2D5" } },
    { "scope": "constant.character", "settings": { "foreground": "#94E2D5" } },
    { "scope": "variable", "settings": { "foreground": "#CDD6F4" } },
    { "scope": "variable.language", "settings": { "foreground": "#F38BA8" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#CDD6F4", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#CBA6F7" } },
    { "scope": "keyword.control", "settings": { "foreground": "#CBA6F7" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#7F849C" } },
    { "scope": "storage", "settings": { "foreground": "#CBA6F7" } },
    { "scope": "storage.type", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#89B4FA" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#CBA6F7" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#89B4FA" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#94E2D5" } },
    { "scope": "support.function", "settings": { "foreground": "#89B4FA" } },
    { "scope": "support.type", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "support.class", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "support.constant", "settings": { "foreground": "#94E2D5" } },
    { "scope": "punctuation", "settings": { "foreground": "#7F849C" } },
    { "scope": "meta.tag", "settings": { "foreground": "#CDD6F4" } },
    { "scope": "meta.brace", "settings": { "foreground": "#7F849C" } },
    { "scope": "markup.heading", "settings": { "foreground": "#CBA6F7", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#A6E3A1" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#F38BA8" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#A6E3A1" } },
    { "scope": "markup.changed", "settings": { "foreground": "#F9E2AF" } },
    { "scope": "markup.list", "settings": { "foreground": "#CDD6F4" } },
    { "scope": "markup.quote", "settings": { "foreground": "#94E2D5", "fontStyle": "italic" } }
  ]
}
