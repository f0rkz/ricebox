  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#4B5263", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#98C379" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#56B6C2" } },
    { "scope": "constant.language", "settings": { "foreground": "#56B6C2" } },
    { "scope": "constant.character", "settings": { "foreground": "#56B6C2" } },
    { "scope": "variable", "settings": { "foreground": "#ABB2BF" } },
    { "scope": "variable.language", "settings": { "foreground": "#E06C75" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#ABB2BF", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#C678DD" } },
    { "scope": "keyword.control", "settings": { "foreground": "#C678DD" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#5C6370" } },
    { "scope": "storage", "settings": { "foreground": "#C678DD" } },
    { "scope": "storage.type", "settings": { "foreground": "#E5C07B" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#61AFEF" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#E5C07B" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#E5C07B" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#61AFEF" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#61AFEF" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#98C379" } },
    { "scope": "support.function", "settings": { "foreground": "#61AFEF" } },
    { "scope": "support.type", "settings": { "foreground": "#E5C07B" } },
    { "scope": "support.class", "settings": { "foreground": "#E5C07B" } },
    { "scope": "support.constant", "settings": { "foreground": "#56B6C2" } },
    { "scope": "punctuation", "settings": { "foreground": "#5C6370" } },
    { "scope": "meta.tag", "settings": { "foreground": "#ABB2BF" } },
    { "scope": "meta.brace", "settings": { "foreground": "#5C6370" } },
    { "scope": "markup.heading", "settings": { "foreground": "#61AFEF", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#98C379" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#E06C75" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#98C379" } },
    { "scope": "markup.changed", "settings": { "foreground": "#E5C07B" } },
    { "scope": "markup.list", "settings": { "foreground": "#ABB2BF" } },
    { "scope": "markup.quote", "settings": { "foreground": "#98C379", "fontStyle": "italic" } }
  ]
}
