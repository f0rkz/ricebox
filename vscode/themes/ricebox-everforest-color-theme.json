  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#5C6A72", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A7C080" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#83C092" } },
    { "scope": "constant.language", "settings": { "foreground": "#83C092" } },
    { "scope": "constant.character", "settings": { "foreground": "#83C092" } },
    { "scope": "variable", "settings": { "foreground": "#D3C6AA" } },
    { "scope": "variable.language", "settings": { "foreground": "#E67E80" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#D3C6AA", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#D699B6" } },
    { "scope": "keyword.control", "settings": { "foreground": "#D699B6" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#859289" } },
    { "scope": "storage", "settings": { "foreground": "#D699B6" } },
    { "scope": "storage.type", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#7FBBB3" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#A7C080" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#7FBBB3" } },
    { "scope": "entity.other.inherited-class", "settings": { "foreground": "#83C092" } },
    { "scope": "support.function", "settings": { "foreground": "#7FBBB3" } },
    { "scope": "support.type", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "support.class", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "support.constant", "settings": { "foreground": "#83C092" } },
    { "scope": "punctuation", "settings": { "foreground": "#859289" } },
    { "scope": "meta.tag", "settings": { "foreground": "#D3C6AA" } },
    { "scope": "meta.brace", "settings": { "foreground": "#859289" } },
    { "scope": "markup.heading", "settings": { "foreground": "#A7C080", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#A7C080" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#E67E80" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#A7C080" } },
    { "scope": "markup.changed", "settings": { "foreground": "#DBBC7F" } },
    { "scope": "markup.list", "settings": { "foreground": "#D3C6AA" } },
    { "scope": "markup.quote", "settings": { "foreground": "#83C092", "fontStyle": "italic" } }
  ]
}
