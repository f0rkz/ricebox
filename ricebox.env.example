# ricebox environment config
# copy to ~/.config/ricebox.env and edit

RICEBOX_HOME_SSID="your-wifi-ssid"
RICEBOX_HOME_LOCATION="Your+City+State+US"
RICEBOX_DPI=192
RICEBOX_VERTICAL_MONITOR=""
RICEBOX_LAPTOP_PANEL="eDP-1"
RICEBOX_DEFAULT_THEME="dark-green"
RICEBOX_TEMP_SENSOR=""
RICEBOX_FONT="0xProto Nerd Font"
RICEBOX_FONT_SIZE=12
RICEBOX_OBSIDIAN_SNIPPETS=""
RICEBOX_FIREFOX_PROFILE=""  # e.g. /home/user/.mozilla/firefox/abc123.default-release
